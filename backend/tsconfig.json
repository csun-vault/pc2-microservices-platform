{
      "compilerOptions": {
            "rootDir": "..",
            "outDir": "./dist",
            "module": "commonjs",
            "target": "es2022",
            "types": [
                  "node"
            ],
            "sourceMap": true,
            "declaration": true,
            "declarationMap": true,
            "noUncheckedIndexedAccess": true,
            "exactOptionalPropertyTypes": true,
            "strict": true,
            "jsx": "react-jsx",
            "verbatimModuleSyntax": false,
            "isolatedModules": true,
            "esModuleInterop": true,
            "allowSyntheticDefaultImports": true,
            "noUncheckedSideEffectImports": true,
            "moduleDetection": "force",
            "skipLibCheck": true,
            "paths": {
                  "@routes/*": ["./src/routes/*"],
                  "@modules/*": ["./src/modules/*"],
                  "@middlewares/*": ["./src/middlewares/*"],
                  "@shared/*": ["../shared/*"],
                  "@libs/*": ["./src/libs/*"],
                  "@type/*": ["./src/types/*"]
            }
      }
}